# ============================================================
# 依赖目录
# ============================================================
node_modules/
.pnp/
.pnp.js

# ============================================================
# 构建输出 - 前端
# ============================================================
dist/
out/
release/
.astro/
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/

# Electron 构建配置目录（保留 nsis-extra.nsh）
frontend/build/*
!frontend/build/nsis-extra.nsh

# 后端打包输出
backend/dist/
backend/build/
frontend/resources/backend/*.exe

# ============================================================
# 构建输出 - Java
# ============================================================
target/
*.class
*.jar
*.war
*.ear

# ============================================================
# 构建输出 - Firmware / ESP-IDF
# ============================================================
# ESP-IDF 构建输出
firmware/**/build/
firmware/**/sdkconfig
firmware/**/sdkconfig.old

# ESP-IDF 组件管理器
firmware/**/managed_components/
firmware/**/dependencies.lock

# Firmware 二进制和固件文件
firmware/**/*.elf
firmware/**/*.map
firmware/**/*.hex

# ============================================================
# Python 虚拟环境和缓存
# ============================================================
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg

# ============================================================
# 日志文件
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# ============================================================
# 环境变量文件
# ============================================================
.env
.env.local
.env.*.local
.env.production
.env.test

# ============================================================
# IDE 和编辑器配置
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# 语言服务器缓存
.clangd/

