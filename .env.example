# LuomiNest 环境变量配置
# 请将此文件复制为 .env 并填入实际的配置值

# === 大模型 API 配置 ===
LLM_API_KEY=your_api_key_here
LLM_MODEL_ID=your_model_id_here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MAX_RETRIES=3
LLM_TIMEOUT=60

# === 模型参数 ===
LLM_EXPERT_TEMPERATURE=0.5
LLM_EXPERT_MAX_TOKENS=2048
LLM_FAST_TEMPERATURE=0.8
LLM_FAST_MAX_TOKENS=512

# === 数据库配置 ===
DB_DB_TYPE=sqlite
DB_SQLITE_PATH=data/luminest.db

# === 硬件通信配置 ===
HW_SERIAL_PORT=COM3
HW_SERIAL_BAUDRATE=9600
HW_TCP_HOST=0.0.0.0
HW_TCP_PORT=8080

# === 日志配置 ===
LOG_LEVEL=INFO

# === 应用配置 ===
APP_NAME=LuomiNest
APP_VERSION=1.0.0
APP_DEBUG=false
