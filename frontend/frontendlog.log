+        shell: bash
         run: |
           cd backend
           python -m venv .venv
-          .venv/Scripts/activate 2>/dev/null || .venv/bin/activate
-          pip install --upgrade pip
-          pip install pyinstaller
-          pip install -e ".[dev]"
+          if [[ "$RUNNER_OS" == "Windows" ]]; then
+            source .venv/Scripts/activate
+          else
+            source .venv/bin/activate
+          fi
+          pip install --upgrade pip
+          pip install pyinstaller
+          pip install -e ".[dev]"
