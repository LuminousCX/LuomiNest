{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "outDir": "./out/main",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*"
  ]
}
