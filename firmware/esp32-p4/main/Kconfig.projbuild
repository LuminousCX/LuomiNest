menu "LuomiNest Configuration"

    config LN_WIFI_SSID
        string "WiFi SSID"
        default "Xiaomi_65DF"
        help
            Default WiFi network name (used when no NVS config saved).

    config LN_WIFI_PASSWORD
        string "WiFi Password"
        default "18033810300xyr"
        help
            Default WiFi network password (used when no NVS config saved).

    config LN_AP_PASSWORD
        string "AP mode password"
        default "18033810300xyr"
        help
            Password for the configuration AP hotspot.

    config LN_WIFI_RECONNECT_MAX_MS
        int "WiFi max reconnect backoff (ms)"
        default 30000
        range 5000 300000

    config LN_MQTT_BROKER
        string "MQTT Broker URI"
        default "mqtt://192.168.1.222:1883"
        help
            Default MQTT broker address (used when no NVS config saved).

    config LN_MQTT_CLIENT_ID
        string "MQTT Client ID"
        default "luominest_p4_01"
        help
            Default MQTT client identifier.

    config LN_MQTT_RECONNECT_MAX_MS
        int "MQTT max reconnect backoff (ms)"
        default 60000
        range 5000 300000

    config LN_FRAME_DEDUP
        bool "Enable frame deduplication"
        default y

    config LN_STATUS_INTERVAL_SEC
        int "Status report interval (seconds)"
        default 10
        range 5 120

    choice LN_ETH_PHY_TYPE
        prompt "Ethernet PHY chip"
        default LN_ETH_PHY_IP101
        help
            Select the PHY chip on your board.

    config LN_ETH_PHY_IP101
        bool "IP101"
    config LN_ETH_PHY_LAN8720
        bool "LAN8720/LAN87xx"
    config LN_ETH_PHY_RTL8201
        bool "RTL8201"
    config LN_ETH_PHY_DP83848
        bool "DP83848"
    config LN_ETH_PHY_KSZ80XX
        bool "KSZ80XX"
    config LN_ETH_PHY_GENERIC
        bool "Generic IEEE 802.3"
    endchoice

    config LN_ETH_PHY_ADDR
        int "PHY address"
        default 1
        range 0 31
        help
            PHY address on the MDIO bus. Use -1 for auto-detect (not all PHYs support this).

    config LN_ETH_CONNECT_TIMEOUT_MS
        int "Ethernet connect timeout (ms)"
        default 8000
        range 2000 30000
        help
            How long to wait for Ethernet to get an IP before falling back to WiFi.

endmenu
